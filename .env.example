# Copy to .env (for local dev) or set these in the Vercel dashboard (Production/Preview).

# Required
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
SECRET_KEY=change-me-to-a-long-random-string
GOOGLE_API_KEY=your-google-ai-studio-key

# Required only after you attach a Vercel Blob store to the project.
# Vercel injects this automatically in its environments; for local dev copy it
# from the Blob store settings.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
